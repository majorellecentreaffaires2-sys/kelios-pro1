# === DATABASE ===
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=majorlle_erp
DB_PORT=3306
# Optionnel : création auto de la base au démarrage (true/false)
# DB_CREATE_IF_NOT_EXISTS=false
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# DB_SECONDARY_NAME=

# Mot de passe du premier SuperAdmin si aucun compte (sinon ignoré)
# INITIAL_ADMIN_PASSWORD=

# === SERVER ===
PORT=5000
NODE_ENV=production

# === JWT ===
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# === EMAIL (Gmail App Password) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Votre Entreprise" <your_email@gmail.com>
SMTP_SECURE=false

# === GOOGLE GEMINI AI (clé serveur uniquement, jamais exposée au navigateur) ===
GEMINI_API_KEY=your_gemini_api_key
# Optionnel : modèle (défaut gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# === APPLICATION ===
APP_NAME=KELIOS Pro
APP_URL=https://your-domain.com
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
