### Copiez en .env et configurez pour cPanel/local

# Serveur
NODE_ENV=production
PORT=3000

# Base de données cPanel MySQL (localhost)
DB_HOST=localhost
DB_USER=facture_user
DB_PASS=your_secure_password
DB_NAME=facture_app_db

# App
APP_URL=https://votre-domaine.com
APP_NAME=Kelios Pro

# JWT (générez une clé forte)
JWT_SECRET=your_very_long_random_jwt_secret_key_here_32_chars_min

# Email
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password

# Gemini IA (optionnel)
GEMINI_API_KEY=your_gemini_key_here

# Rate limit / Security
MAX_LOGIN_ATTEMPTS=5
PASSWORD_SALT_ROUNDS=12

