#!/bin/bash

# Configuration npm optimisée pour le CI/CD
# Résout les problèmes de dépendances et cache

# Cache optimisé pour les builds CI
cache=/tmp/npm-cache

# Préférence pour la résolution des dépendances
prefer-offline=true

# Timeout augmenté pour les réseaux lents
fetch-timeout=60000

# Nombre maximum de tentatives
fetch-retry-millis=10000

# Utiliser le registre npm par défaut
registry=https://registry.npmjs.org/

# Désactiver les avertissements de peer dependency (temporairement)
strict-peer-deps=false

# Logs détaillés pour le debugging
loglevel=warn

# Utiliser npm 7+ avec lockfile version 2
lockfile-version=2

# Supprimer les configurations problématiques
# fetch-retry-millis
